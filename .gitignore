# ============================================================
# OpenAuthority - Git Ignore
# ============================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Wrangler / Cloudflare
.wrangler/
.dev.vars
.env
.env.*
!.env.example

# macOS
.DS_Store

# Logs
logs/
*.log

# Runtime / temp
tmp/
temp/
.cache/

# Build artifacts
dist/
build/
coverage/

# Frontend build artifacts
frontend/dist/
frontend/build/
frontend/.cache/

# TypeScript
*.tsbuildinfo

# IDE / Editors
.vscode/
.idea/

# Local notes
notes.txt

# Private keys / certificates
*.pem
*.key
*.p12
*.pfx
*.der
*.csr

# Raw/base64 key exports
private_key*
public_key*
*_raw.txt
*_base64.txt

# Local Wrangler config overrides
wrangler.toml.local

# Database dumps / local sqlite
*.sqlite
*.sqlite3
*.db

# Local test artifacts
test-output/
artifacts/

# Sensitive exports
exports/
snapshots/

# Optional: local audit exports
audit-log-export.json
trust-store-export.json

.dev.vars*
!.dev.vars.example
